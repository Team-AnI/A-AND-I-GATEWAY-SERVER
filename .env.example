# Gateway runtime
# [optional, default=8080]
SERVER_PORT=8080
# [optional, defaults=spring.profiles.active then default / 0.0.1-SNAPSHOT / local]
APP_ENV=local
APP_VERSION=0.0.1-SNAPSHOT
# HOSTNAME is normally supplied by the runtime. Uncomment only to override the logging instance id.
# HOSTNAME=local

# Gateway authentication
# [production required, secret] Must be at least 32 bytes. The built-in value is for local development only.
AUTH_JWT_SECRET=replace-with-at-least-32-byte-secret
# [production required, defaults=http://localhost:9000 / aandi-gateway]
AUTH_ISSUER_URI=https://auth.example.com
AUTH_AUDIENCE=aandi-gateway
# [optional, default=30]
AUTH_JWT_CLOCK_SKEW_SECONDS=30
# [optional, default=true] false permits every route and must not be used in production.
GATEWAY_AUTH_ENABLED=true
# [required, secret, no default] Authenticates the internal cache invalidation endpoint.
INTERNAL_EVENT_TOKEN=replace-with-strong-random-token

# Gateway routing targets
# [production required] Internal service URI examples; application.yaml has localhost development defaults.
AUTH_SERVICE_URI=http://auth-service.internal:8080
REPORT_SERVICE_URI=http://report-service.internal:8080
POST_SERVICE_URI=http://post-service.internal:8080
ONLINE_JUDGE_SERVICE_URI=http://online-judge-service.internal:8080

# Redis
# [optional, defaults=localhost / 6379 / empty]
REDIS_HOST=localhost
REDIS_PORT=6379
# [production secret]
REDIS_PASSWORD=

# Gateway cache and management
# [optional, default=24h]
TOKEN_CACHE_TTL=24h
# [optional, defaults=9090 / 127.0.0.1]
MANAGEMENT_SERVER_PORT=9090
MANAGEMENT_SERVER_ADDRESS=127.0.0.1

# Gateway request policy
# [optional, defaults=2MB / 16KB]
MAX_REQUEST_BODY_SIZE=2MB
MAX_REQUEST_HEADER_SIZE=16KB
# [optional, default=false] Set true only when the trusted proxy supplies the HTTPS scheme.
ENFORCE_HTTPS=false
# [optional, defaults=true]
ENFORCE_METHOD_PATH_ALLOWLIST=true
ENFORCE_JSON_CONTENT_TYPE=true
PREVALIDATE_REFRESH_TOKEN_TYPE=true
# [optional, default=empty] Comma-separated host names. Empty disables host allowlisting.
ALLOWED_HOSTS=
# [optional, default=true]
ALLOW_PRIVATE_IP_HOST=true
# [optional, default=https://*] Comma-separated origin patterns.
CORS_ALLOWED_ORIGIN_PATTERNS=https://*

# Gateway auth rate limiting
# [optional, defaults=true / 10 / 30 / 30]
AUTH_RATE_LIMIT_ENABLED=true
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=10
AUTH_REFRESH_RATE_LIMIT_PER_MINUTE=30
AUTH_LOGOUT_RATE_LIMIT_PER_MINUTE=30
# [optional, default=10000, valid=1..1000000] Four rows allocate 4 x slots; invalid values fail startup, and collisions can cause conservative false-positive 429 responses.
AUTH_RATE_LIMIT_COUNTER_SLOTS=10000

# Monitor Bot core
# [required, no default] Public identifier; not a secret.
DISCORD_APPLICATION_ID=
# [required, no default] Discord interaction verification key; not a secret.
DISCORD_PUBLIC_KEY=
# [conditional secret] Required for command registration and channel/dashboard/alert messages.
DISCORD_BOT_TOKEN=
# [recommended access restriction] Empty allows interactions from any guild/role.
DISCORD_ALLOWED_GUILD_ID=
DISCORD_ALLOWED_ROLE_IDS=
# [optional, defaults=8088 / true / false / guild / false]
BOT_HTTP_PORT=8088
DISCORD_EPHEMERAL_RESPONSES=true
DISCORD_REGISTER_COMMANDS=false
DISCORD_COMMAND_SCOPE=guild
STRICT_STARTUP_CHECKS=false

# Monitor Bot AWS and CloudWatch
# AWS credentials are resolved by the AWS SDK default credential chain; prefer an IAM role over static env secrets.
# [optional, defaults shown]
AWS_REGION=ap-northeast-2
CLOUDWATCH_QUERY_TIMEOUT_SECONDS=8
CLOUDWATCH_QUERY_POLL_INTERVAL_MS=500
CLOUDWATCH_QUERY_LIMIT=20
CLOUDWATCH_MAX_LOG_GROUPS_PER_QUERY=5
MAX_CLOUDWATCH_QUERIES_PER_TICK=6
LOG_GROUP_GATEWAY=/a-and-i/gateway
LOG_GROUP_AUTH=/a-and-i/auth
LOG_GROUP_REPORT=/a-and-i/prod/report
LOG_GROUP_ONLINE_JUDGE=/a-and-i/online-judge
LOG_GROUP_POST=/a-and-i/prod/tech-blog

# Monitor Bot service health
# [optional] Gateway has the shown default; the other health URLs default to empty.
HEALTH_REQUEST_TIMEOUT_MS=2000
HEALTH_URL_GATEWAY=http://gateway:9090/actuator/health/readiness
HEALTH_URL_AUTH=
HEALTH_URL_REPORT=
HEALTH_URL_ONLINE_JUDGE=
HEALTH_URL_POST=

# Monitor Bot assignment operations
# Reuses AUTH_SERVICE_URI and REPORT_SERVICE_URI above.
# [conditional secret, no default] Required for assignment Admin API reads and token refresh.
OPS_ADMIN_REFRESH_TOKEN=
# [optional, default=7]
ASSIGNMENT_STALE_GRACE_DAYS=7

# Monitor Bot state, dashboard, and alerts
# [optional, defaults shown]
MONITOR_BOT_STATE_PATH=/var/lib/monitor-bot/state.json
DASHBOARD_ENABLED=false
DISCORD_DASHBOARD_CHANNEL_ID=
DASHBOARD_REFRESH_INTERVAL_SECONDS=300
DASHBOARD_SINCE=30m
ALERT_ENABLED=false
DISCORD_ALERT_CHANNEL_ID=
ALERT_POLL_INTERVAL_SECONDS=180
ALERT_COOLDOWN_SECONDS=900
ALERT_5XX_THRESHOLD_5M=3
ALERT_ERROR_THRESHOLD_5M=5
ALERT_HEALTH_DOWN_CONSECUTIVE=2
ALERT_NO_LOGS_MINUTES=30
ALERT_COPY_API_5XX_THRESHOLD_5M=1
