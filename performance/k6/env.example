# Copy to a local env file if needed. Do not commit real tokens.

BASE_URL=http://localhost:8080
UPSTREAM_BASE_URL=http://localhost:18080
ALLOW_REMOTE_LOAD_TEST=false
TARGET_ENVIRONMENT=local
REMOTE_TARGET_ALLOWLIST=

LOAD_VUS=5
TEST_DURATION=1m
SLEEP_SECONDS=0.1
# P95_THRESHOLD_MS is intentionally blank by default.
P95_THRESHOLD_MS=
RESULT_DIR=performance/results

PUBLIC_ROUTE_PATH=/v2/blogs
PROTECTED_ROUTE_PATH=/v1/me
FORBIDDEN_ROUTE_PATH=/v1/admin/ping
RATE_LIMIT_PATH=/v1/auth/login

PAYLOAD_BYTES=1024
MOCK_DELAY_MS=50
MOCK_STATUS=200
RUN_REPEAT=3

# Use ACCESS_TOKEN or TEST_JWT for protected route and 403 contract checks.
ACCESS_TOKEN=
TEST_JWT=
USER_ACCESS_TOKEN=
ADMIN_ACCESS_TOKEN=
SKIP_AUTH_SCENARIOS=false

# Local-only JWT settings used by run-local.sh.
AUTH_ISSUER_URI=http://localhost:9000
AUTH_AUDIENCE=aandi-gateway
PERFORMANCE_JWT_SECRET=performance-local-only-jwt-secret-at-least-32-bytes

# Keep the repository default unless you intentionally run Gateway with a different local policy.
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=10

# Compose-local connection failure target for Gateway-owned 502 checks.
PERFORMANCE_REPORT_SERVICE_URI=http://127.0.0.1:65534
GATEWAY_MANAGEMENT_PORT=9090
KEEP_PERFORMANCE_STACK=false
