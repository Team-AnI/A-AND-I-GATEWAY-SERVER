<mxfile host="app.diagrams.net" modified="2026-06-04T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="gateway-ops-flow" name="운영 알림 Trace Drilldown 흐름">
    <mxGraphModel dx="1200" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="운영 알림과 Trace Drilldown 흐름" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;fontColor=#0b1533;" vertex="1" parent="1">
          <mxGeometry x="320" y="28" width="560" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="error" value="1. 오류 발생&#xa;Gateway / Downstream&#xa;HTTP 5xx 또는 정책 실패&#xa;traceId 생성" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ef4444;fontColor=#334155;fontStyle=1;arcSize=8;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="60" y="155" width="190" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="structured-log" value="2. 구조화 로그&#xa;traceId, status&#xa;error.code, severity&#xa;CloudWatch로 수집" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#334155;fontStyle=1;arcSize=8;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="300" y="155" width="200" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="logs-insights" value="3. Logs 조회&#xa;Logs Insights query&#xa;traceId 기준 검색&#xa;원인 후보 추출" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#334155;fontStyle=1;arcSize=8;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="550" y="155" width="200" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="alert-routing" value="4. Alert 분기&#xa;general / critical&#xa;critical만 role mention&#xa;@everyone 차단" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#0f766e;fontColor=#334155;fontStyle=1;arcSize=8;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="800" y="155" width="210" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="operator" value="5. 운영자 추적&#xa;Discord 버튼 또는 /ops logs mode:trace query:&amp;lt;traceId&amp;gt;&#xa;관련 로그를 모아 장애 원인을 확인합니다." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontColor=#334155;fontStyle=1;arcSize=8;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="410" y="455" width="370" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="note" value="민감정보 기준: token, guild ID, role ID, 운영 URL, 사용자 개인정보는 데모와 문서에 노출하지 않습니다." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontColor=#475569;arcSize=8;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="1080" height="52" as="geometry"/>
        </mxCell>
        <mxCell id="edge1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#64748b;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="error" target="structured-log">
